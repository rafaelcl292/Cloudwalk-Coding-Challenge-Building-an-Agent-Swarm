{
  "name": "cloudwalk-agent-swarm",
  "version": "0.1.0",
  "private": true,
  "description": "Bun, React, Clerk, and AI SDK implementation of the CloudWalk agent swarm challenge.",
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "start": "NODE_ENV=production bun src/index.ts",
    "build": "bun run build.ts",
    "db:migrate": "bun run scripts/migrate.ts",
    "db:seed": "bun run scripts/seed.ts",
    "rag:ingest": "bun run scripts/ingest-knowledge.ts",
    "aws:deploy": "bun run scripts/aws-deploy.ts deploy",
    "aws:status": "bun run scripts/aws-deploy.ts status",
    "aws:down": "bun run scripts/aws-deploy.ts down",
    "aws:destroy": "bun run scripts/aws-deploy.ts destroy",
    "challenge:e2e": "bun run scripts/challenge-e2e.ts",
    "test": "bun test",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint --type-aware --type-check src scripts build.ts",
    "lint:fix": "oxlint --type-aware --type-check --fix src scripts build.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@ai-sdk/gateway": "^3.0.114",
    "@ai-sdk/openai": "^3.0.63",
    "@ai-sdk/react": "^3.0.182",
    "@clerk/backend": "^3.4.7",
    "@clerk/react": "^6.6.2",
    "@clerk/ui": "^1.9.1",
    "ai": "^6.0.180",
    "bun-plugin-tailwind": "^0.1.2",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwindcss": "^4.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.64.0",
    "oxlint-tsgolint": "^0.22.1"
  },
  "lint-staged": {
    "*": "oxfmt --no-error-on-unmatched-pattern",
    "*.{js,jsx,ts,tsx,mjs,cjs}": "bun run lint --"
  }
}
